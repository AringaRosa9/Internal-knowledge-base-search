# ============================================================
# LLM Configuration / LLM設定 / LLM配置
# ============================================================
# Provider: "anthropic" or "openai_compatible"
# "openai_compatible" works with OpenRouter, OneAPI, NewAPI, etc.
LLM_PROVIDER=anthropic

# --- Option A: Anthropic (default) ---
ANTHROPIC_API_KEY=sk-ant-xxxxx

# --- Option B: OpenAI-Compatible (OpenRouter, etc.) ---
# CUSTOM_LLM_BASE_URL=https://openrouter.ai/api/v1
# CUSTOM_LLM_API_KEY=sk-or-xxxxx
# CUSTOM_LLM_MODEL=google/gemini-2.0-flash-exp:free

# ============================================================
# Embedding Configuration / Embedding設定 / Embedding配置
# ============================================================
# Provider: "openai" or "openai_compatible"
EMBEDDING_PROVIDER=openai

# --- Option A: OpenAI (default) ---
OPENAI_API_KEY=sk-xxxxx

# --- Option B: OpenAI-Compatible ---
# CUSTOM_EMBEDDING_BASE_URL=https://openrouter.ai/api/v1
# CUSTOM_EMBEDDING_API_KEY=sk-or-xxxxx
# CUSTOM_EMBEDDING_MODEL=text-embedding-3-small

# ============================================================
# Application / アプリケーション設定
# ============================================================
APP_HOST=0.0.0.0
APP_PORT=8000
FRONTEND_URL=http://localhost:3000
DATABASE_URL=sqlite+aiosqlite:///./shanai.db
